# ============================================================
# claude-groupchat 配置（v0.2：SQLite + 话题房间 + WebUI）
# ============================================================
# 拷贝本文件为 .env 后按需修改。
# server 端和 client 端共用一份 .env（无关字段可留默认值）。

# ----- server 端：监听 -----
# 监听端口（WebSocket / HTTP 上传下载 / WebUI 全部共用同一端口）
PORT=7600
# 监听网卡（局域网建议 0.0.0.0，仅本机调试可用 127.0.0.1）
BIND_HOST=0.0.0.0

# ----- client 端：连接 -----
# 指向 server 的完整 URL（http/https；WS 自动推导成 ws/wss 同端口）
# 例：CHAT_SERVER_URL=http://192.168.1.50:7600
CHAT_SERVER_URL=http://127.0.0.1:7600

# ----- server 端：SQLite 存储 -----
# 数据库文件路径（相对项目根目录或绝对路径）。data/ 目录已 gitignore
SQLITE_PATH=data/cgc.db
# 文件存储目录（相对项目根目录或绝对路径）
UPLOAD_DIR=uploads
# 单文件上限（MB）
MAX_FILE_SIZE_MB=50
# 推送给新加入客户端的最近历史消息条数
HISTORY_PUSH_COUNT=20
# WebUI 历史分页默认每页大小
WEB_PAGE_SIZE=50

# ----- server 端：WebUI 鉴权（express-session 内存存储）-----
# WebUI 登录用户名 / 密码。**强烈建议修改默认值**
WEB_USERNAME=admin
WEB_PASSWORD=changeme
# session 加密密钥（任意随机字符串）
WEB_SESSION_SECRET=please-change-me-to-a-random-string

# ----- client 端：身份 -----
# 留空则自动用 hostname:projectDir 推断
CHAT_PEER_ID=
# 可选显示名（留空时显示 peerId）
CHAT_PEER_LABEL=

# ----- 日志 -----
LOG_LEVEL=info
LOG_DIR=logs
HTTP_LOG_DIR=http_logs
LOG_ROTATE_PATTERN=YYYY-MM-DD
LOG_ZIPPED_ARCHIVE=false
LOG_MAX_FILES=14d
