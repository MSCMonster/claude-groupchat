# ============================================================
# claude-groupchat 配置
# ============================================================
# 拷贝本文件为 .env 后按需修改。
# server 端和 client 端共用一份 .env（无关字段可留默认值）。

# ----- server 端：监听 -----
# 监听端口（WS 与 HTTP 共用同一端口；WS 走 HTTP upgrade）
PORT=7600
# 监听网卡（局域网建议 0.0.0.0，仅本机调试可用 127.0.0.1）
BIND_HOST=0.0.0.0

# ----- client 端：连接 -----
# 指向 server 的完整 URL（http/https；WS 自动推导成 ws/wss 同端口）
# 例：CHAT_SERVER_URL=http://192.168.1.50:7600
CHAT_SERVER_URL=http://127.0.0.1:7600

# ----- server 端：Redis（仅 server 端需要）-----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Redis key 前缀，便于多实例共存
REDIS_PREFIX=cgc:

# ----- server 端：消息与文件 -----
# 推送给新加入客户端的历史消息条数
HISTORY_PUSH_COUNT=10
# Redis 中保留的最大历史消息条数（防止无限堆积；server 重启会清空）
HISTORY_MAX_COUNT=1000
# 文件存储目录（相对项目根目录）
UPLOAD_DIR=uploads
# 文件保留时长（小时）
FILE_TTL_HOURS=24
# 清理任务运行间隔（分钟）
CLEANUP_INTERVAL_MINUTES=30
# 单文件上限（MB）
MAX_FILE_SIZE_MB=50

# ----- client 端：身份 -----
# 留空则自动用 hostname:projectDir 推断
CHAT_PEER_ID=
# 可选显示名（留空时显示 peerId）
CHAT_PEER_LABEL=

# ----- 日志 -----
LOG_LEVEL=info
LOG_DIR=logs
HTTP_LOG_DIR=http_logs
LOG_ROTATE_PATTERN=YYYY-MM-DD
LOG_ZIPPED_ARCHIVE=false
LOG_MAX_FILES=14d
